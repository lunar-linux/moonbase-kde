          MODULE=sweeper
         VERSION=26.04.2
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=$KDE_URL/stable/release-service/$VERSION/src
      SOURCE_VFY=sha256:f87b9fb6f0091beb34c229ba0e05da1871955d5f003bb2b109b091a98dce0c97
   MODULE_PREFIX=${KDE_INSTALL_DIR:-/usr}
        WEB_SITE=http://www.kde.org/applications/utilities/sweeper/
         ENTERED=20120125
         UPDATED=20260604
           SHORT="A system cleaner"

cat << EOF
Sweeper helps to clean unwanted traces the user leaves on the systemd
and to regain disk space removing unused temporary files.
    It can remove web-related traces: cookies, history, cache
    It can remove the image thumbnails cache
    It can also clean the applications and documentes history
EOF
