          MODULE=juk
         VERSION=26.04.2
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=$KDE_URL/stable/release-service/$VERSION/src
      SOURCE_VFY=sha256:0d321a0cc47b8d402449fbd701e2a324f32494ead7f5ca3753a4089dc6d6de20
   MODULE_PREFIX=${KDE_INSTALL_DIR:-/usr}
        WEB_SITE=http://www.kde.org/applications/multimedia/juk/
         ENTERED=20120801
         UPDATED=20260604
           SHORT="An audio jukebox"

cat << EOF
JuK is an audio jukebox application, supporting collections of MP3, Ogg Vorbis,
and FLAC audio files. It allows you to edit the "tags" of your audio files,
and manage your collection and playlists. It's main focus, in fact, is on music
management.
EOF
