          MODULE=akonadiconsole
         VERSION=26.04.3
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=$KDE_URL/stable/release-service/$VERSION/src
      SOURCE_VFY=sha256:d27092a87af4da2d5e3a15eb5a73497081438f6545c2d86c2f2d7ff2db5364e5
   MODULE_PREFIX=${KDE_INSTALL_DIR:-/usr}
        WEB_SITE=https://techbase.kde.org/KDE_PIM/Akonadi/Development_Tools
         ENTERED=20171201
         UPDATED=20260714
           SHORT="A tool for developers working with Akonadi"

cat << EOF
Akonadi Console is a tool for developers working with Akonadi or on Akonadi
itself.
It provides GUI for
  managing agents and resources
  retrieving, checking and even manipulating data
  monitoring communication between Akonadi server and its clients
  convenience access to the database used by the server
EOF
