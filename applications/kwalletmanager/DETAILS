          MODULE=kwalletmanager
         VERSION=25.12.3
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=$KDE_URL/stable/release-service/$VERSION/src
      SOURCE_VFY=sha256:b74adfa977f5c3aaae9cb4e225c30acfb1999246820c6c485d45367f1da0ad89
   MODULE_PREFIX=${KDE_INSTALL_DIR:-/usr}
        WEB_SITE=http://www.kde.org/applications/system/kwalletmanager/
         ENTERED=20140713
         UPDATED=20260305
           SHORT="Manage the passwords on your system"

cat << EOF
KWalletManager is a tool to manage the passwords on your system. By using the
KDE wallet subsystem it not only allows you to keep your own secrets but also
to access and manage the passwords of every application that integrates with
the wallet.
EOF
