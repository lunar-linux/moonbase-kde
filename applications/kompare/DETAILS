          MODULE=kompare
         VERSION=26.04.2
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=$KDE_URL/stable/release-service/$VERSION/src
      SOURCE_VFY=sha256:7130ee492da6b12f0b33e705b70514cd5eb11019b5799c96376f995ca052fa37
   MODULE_PREFIX=${KDE_INSTALL_DIR:-/usr}
        WEB_SITE=http://www.kde.org/applications/development/kompare/
         ENTERED=20130814
         UPDATED=20260604
           SHORT="A diff patch frontend"

cat << EOF
Kompare is a GUI front-end program that enables differences between source files to
be viewed and merged. It can be used to compare differences on files or the contents
of folders, and it supports a variety of diff formats and provide many options to
customize the information level displayed.
EOF
