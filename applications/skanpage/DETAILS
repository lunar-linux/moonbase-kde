      SOURCE_URL=$KDE_URL/stable/$MODULE/$VERSION
      SOURCE_VFY=sha256:fd33ecdd76fda81d29398abd4892842c8d8d9a6e3677fd50dc95876f42519d69
        WEB_SITE=https://apps.kde.org/skanpage/
