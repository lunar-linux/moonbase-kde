          MODULE=kmouth
         VERSION=26.04.3
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=$KDE_URL/stable/release-service/$VERSION/src
      SOURCE_VFY=sha256:a608105dd8f519c53d81ffc8a9e6578b31e310b6c9333c42d369507b8d5fe1c1
   MODULE_PREFIX=${KDE_INSTALL_DIR:-/usr}
        WEB_SITE=http://www.kde.org/applications/utilities/kmouth/
         ENTERED=20120125
         UPDATED=20260714
           SHORT="Enable your computer to speak"

cat << EOF
KMouth is a program which enables persons that cannot speak to let their computer
speak, e.g. mutal people or people who have lost their voice. It has a text input
field and speaks the sentences that you enter. It also has support for user
defined phrasebooks.
EOF
