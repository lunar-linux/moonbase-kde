      SOURCE_URL=$KDE_URL/stable/release-service/$VERSION/src
      SOURCE_VFY=sha256:7813106878bde5286f45c005647048217b2e46444c8ac2ef76480a2de88e7f0f
        WEB_SITE=https://apps.kde.org/neochat
