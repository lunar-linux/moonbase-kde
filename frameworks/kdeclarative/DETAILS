          MODULE=kdeclarative
         VERSION=6.24.0
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=$KDE_URL/stable/frameworks/$(module_version kf5)
      SOURCE_VFY=sha256:d00d697aa8ce7a5a16864e92bc74f52adb2b3008881d6e12b66155a80b136915
        WEB_SITE=https://projects.kde.org/projects/frameworks/kdeclarative
         ENTERED=20150205
         UPDATED=20260313
           SHORT="integration of QML and KDE work spaces"

cat << EOF
KDeclarative provides integration of QML and KDE work spaces.
It's comprises two parts: a library used by the C++ part of your application
to intergrate QML with KDE Frameworks specific features, and a series of
QML imports that offer bindings to some of the Frameworks.
EOF
