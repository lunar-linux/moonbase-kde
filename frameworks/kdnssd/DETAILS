          MODULE=kdnssd
         VERSION=6.27.0
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=$KDE_URL/stable/frameworks/$(module_version kf5)
      SOURCE_VFY=sha256:a60746aca1ce6cfd2fbd20144bc4869d2b00d04b597aedab3dd37a345fb03bb4
        WEB_SITE=https://projects.kde.org/projects/frameworks/kdnssd
         ENTERED=20150205
         UPDATED=20260611
           SHORT="Network service discovery using Zeroconf"

cat << EOF
KDNSSD is a library for handling the DNS-based Service Discovery Protocol
(DNS-SD), the layer of [Zeroconf](http://www.zeroconf.org) that allows network
services, such as printers, to be discovered without any user intervention or
centralized infrastructure.
EOF
