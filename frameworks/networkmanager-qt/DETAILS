          MODULE=networkmanager-qt
         VERSION=6.28.0
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=$KDE_URL/stable/frameworks/$(module_version kf5)
      SOURCE_VFY=sha256:30604204bb00115f515146d05f981aa1f9824e14c0c537a1ec397581ac5d912e
        WEB_SITE=https://projects.kde.org/projects/frameworks/knetworkmanager
