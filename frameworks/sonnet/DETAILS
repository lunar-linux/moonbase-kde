          MODULE=sonnet
         VERSION=6.28.0
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=$KDE_URL/stable/frameworks/$(module_version kf5)
      SOURCE_VFY=sha256:66c6b439950bec7f67b730e6e49d6d30cba21dad115e4a47c4fe46014cc19c3b
        WEB_SITE=https://projects.kde.org/projects/frameworks/sonnet
         ENTERED=20150205
         UPDATED=20260721
           SHORT="multi-language spell checker"

cat << EOF
Sonnet is a plugin-based spell checking library for Qt-based
applications. It supports several different plugins, including
HSpell, Enchant, ASpell and HUNSPELL.

It also supports automated language detection, based on a
combination of different algorithms.
EOF
