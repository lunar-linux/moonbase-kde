      SOURCE_URL=$KDE_URL/stable/frameworks/$(module_version kf5)
      SOURCE_VFY=sha256:be8ce0c791900a1f55e9973bf5faefbe172740424ac9f254ba541552ba3ccb06
        WEB_SITE=https://projects.kde.org/projects/frameworks/kidletime
