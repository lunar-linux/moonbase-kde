          MODULE=ki18n
         VERSION=6.27.0
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=$KDE_URL/stable/frameworks/$(module_version kf5)
      SOURCE_VFY=sha256:cd812ae95b0e95b40e46a50b9dea6d188eec001be96b1e1a5d962730e5f9bc58
        WEB_SITE=https://projects.kde.org/projects/frameworks/ki18n
         ENTERED=20150205
         UPDATED=20260611
           SHORT="gettext based UI text internationalization"

cat << EOF
KI18n provides functionality for internationalizing user interface text
in applications, based on the GNU Gettext translation system.
It wraps the standard Gettext functionality, so that the programmers
and translators can use the familiar Gettext tools and workflows.
EOF
